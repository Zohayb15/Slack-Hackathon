# Slack (api.slack.com/apps -> your app)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Anthropic (console.anthropic.com -> API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Google Calendar OAuth (Google Cloud Console -> Credentials, Desktop app type)
# Run `python3 scripts/get_google_refresh_token.py` to get the refresh token.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# IANA timezone used to resolve relative dates and create events
DEFAULT_TIMEZONE=America/New_York
